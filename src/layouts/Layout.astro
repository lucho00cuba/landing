---
import "../styles/global.css";
import { profile } from "../config";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  noindex?: boolean;
}

const {
  title,
  description = "Staff DevOps / Platform Engineer portfolio. Cloud architecture, Kubernetes, IaC, CI/CD, and observability — Madrid, Spain.",
  canonical = Astro.url.pathname,
  ogImage = "/my-avatar.png",
  ogImageWidth = 256,
  ogImageHeight = 256,
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://justme.ovh");
const canonicalUrl = new URL(canonical, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const robots = noindex ? "noindex, nofollow" : "index, follow";
const twitterHandle = "@zzjust_mezz";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  jobTitle: profile.job,
  url: siteUrl.toString(),
  email: profile.email,
  address: {
    "@type": "PostalAddress",
    addressLocality: "Madrid",
    addressCountry: "ES",
  },
  sameAs: profile.socials.map((s) => s.link),
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: title,
  url: canonicalUrl,
  description,
};
---

<!doctype html>
<html lang="en" prefix="og: http://ogp.me/ns#">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Identity -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={profile.name} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#1a1a1a" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Luis Octavio | Portfolio" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:alt" content={`${profile.name} — ${profile.job}`} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={twitterHandle} />
    <meta name="twitter:creator" content={twitterHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={`${profile.name} — ${profile.job}`} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <!-- Performance hints for external resources -->
    <link rel="preconnect" href="https://unpkg.com" />
    <link rel="dns-prefetch" href="https://unpkg.com" />
    <link rel="preconnect" href="https://avatars.githubusercontent.com" />
  </head>
  <body>
    <main>
      <slot />
    </main>
    <script
      type="module"
      src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"
    ></script>
    <script
      nomodule
      src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>
  </body>
</html>
