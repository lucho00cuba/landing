---
import TestimonialItem from "@components/TestimonialItem.astro";
import { profile } from '../config';

const testimonials = profile.testimonials
---

<section class="testimonials">
  <h3 class="h3 testimonials-title">Testimonials</h3>
  <ul class="testimonials-list has-scrollbar">
    {testimonials.map((testimonial) => <TestimonialItem {...testimonial} />)}
  </ul>
</section>

<div class="modal-container" aria-hidden="true" data-modal-container>
  <div class="overlay" data-overlay />
  <section
    class="testimonials-modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="testimonial-modal-title"
  >
    <button class="modal-close-btn" type="button" aria-label="Close testimonial modal" data-modal-close-btn>
      <ion-icon name="close-outline" />
    </button>
    <div class="modal-img-wrapper">
      <figure class="modal-avatar-box">
        <img
          src={testimonials[0].avatar}
          alt={testimonials[0].name}
          width="80"
          data-modal-img
        />
      </figure>
      <img src="/icon-quote.svg" alt="quote icon" />
    </div>
    <div class="modal-content">
      <h4 id="testimonial-modal-title" class="h3 modal-title" data-modal-title>
        {testimonials[0].name}
      </h4>
      <time datetime={testimonials[0].date} data-modal-date>
        {new Date(testimonials[0].date).toLocaleDateString("en-US", {
          month: "short",
          day: "numeric",
          year: "numeric",
        })}
      </time>
      <div data-modal-text>
        <p>{testimonials[0].text}</p>
      </div>
    </div>
  </section>
</div>

<script type="module">
  document.addEventListener("DOMContentLoaded", () => {
    const testimonialsItem = document.querySelectorAll(
      "[data-testimonials-item]"
    );
    const modalContainer = document.querySelector("[data-modal-container]");
    const modalCloseBtn = document.querySelector("[data-modal-close-btn]");
    const overlay = document.querySelector("[data-overlay]");

    const modalImg = document.querySelector("[data-modal-img]");
    const modalTitle = document.querySelector("[data-modal-title]");
    const modalDate = document.querySelector("[data-modal-date]");
    const modalText = document.querySelector("[data-modal-text]");

    if (
      testimonialsItem.length === 0 ||
      !modalContainer ||
      !modalCloseBtn ||
      !overlay ||
      !modalImg ||
      !modalTitle ||
      !modalDate ||
      !modalText
    ) {
      return;
    }

    const testimonialsModalFunc = () => {
      modalContainer.classList.toggle("active");
      overlay.classList.toggle("active");
      const isOpen = modalContainer.classList.contains("active");
      modalContainer.setAttribute("aria-hidden", String(!isOpen));
      if (isOpen) modalCloseBtn.focus();
    };

    const openFromItem = (item) => {
      const avatar = item.querySelector("[data-testimonials-avatar]");
      const title = item.querySelector("[data-testimonials-title]");
      const text = item.querySelector("[data-testimonials-text]");
      const date = item.querySelector("time");

      if (!avatar || !title || !text) return;

      modalImg.src = avatar.src;
      modalImg.alt = avatar.alt;
      modalTitle.textContent = title.textContent;
      modalText.innerHTML = text.innerHTML;
      if (date) {
        modalDate.setAttribute("datetime", date.getAttribute("datetime") || "");
        modalDate.textContent = date.textContent;
      }
      if (!modalContainer.classList.contains("active")) {
        testimonialsModalFunc();
      }
    };

    testimonialsItem.forEach((item) => {
      item.addEventListener("click", () => openFromItem(item));
      item.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          openFromItem(item);
        }
      });
    });

    modalCloseBtn.addEventListener("click", testimonialsModalFunc);
    overlay.addEventListener("click", testimonialsModalFunc);
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && modalContainer.classList.contains("active")) {
        testimonialsModalFunc();
      }
    });
  });
</script>
