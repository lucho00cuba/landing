---
const formId = "mdajwqjn";
---

<article
  id="contact"
  class="contact"
  data-page="contact"
  aria-labelledby="contact-title"
>
  <header>
    <h2 id="contact-title" class="h2 article-title">Contact</h2>
  </header>

  <div class="contact-body">
    <section class="mapbox" data-mapbox aria-label="Location map">
      <figure>
        <iframe
          src="https://maps.google.com/maps?width=600&height=400&hl=en&q=Madrid&t=&z=11&ie=UTF8&iwloc=B&output=embed"
          title="Map showing Madrid, Spain"
          width="400"
          height="400"
          loading="lazy"
        ></iframe>
      </figure>
    </section>

    <section class="contact-form">
      <div class="form-header">
        <h3 id="contact-form-title" class="h3 form-title">Send a message</h3>
        <p class="form-lead">
          Have a project in mind or want to connect? Drop me a line and I will get back to you.
        </p>
      </div>

      <p data-fs-success class="form-status form-status-success" role="status" aria-live="polite"></p>
      <p data-fs-error class="form-status form-status-error" role="alert" aria-live="assertive"></p>

      <form id="contact-form" class="form" aria-labelledby="contact-form-title" novalidate>
        <div class="input-wrapper">
          <div class="form-field">
            <label class="form-label" for="fullname">Full name</label>
            <input
              id="fullname"
              type="text"
              name="name"
              class="form-input"
              placeholder="John Doe"
              autocomplete="name"
              required
              data-fs-field
            />
            <span data-fs-error="name" class="field-error" aria-live="polite"></span>
          </div>

          <div class="form-field">
            <label class="form-label" for="email">Email address</label>
            <input
              id="email"
              type="email"
              name="email"
              class="form-input"
              placeholder="you@example.com"
              autocomplete="email"
              required
              data-fs-field
            />
            <span data-fs-error="email" class="field-error" aria-live="polite"></span>
          </div>
        </div>

        <div class="form-field">
          <label class="form-label" for="message">Message</label>
          <textarea
            id="message"
            name="message"
            class="form-input"
            placeholder="Tell me about your project or opportunity..."
            required
            data-fs-field
          ></textarea>
          <span data-fs-error="message" class="field-error" aria-live="polite"></span>
        </div>

        <button class="form-btn" type="submit" data-fs-submit-btn>
          <ion-icon name="paper-plane"></ion-icon>
          <span>Send Message</span>
        </button>
      </form>
    </section>
  </div>
</article>

<script>
  import { initForm } from "@formspree/ajax";
  initForm({ formElement: "#contact-form", formId: "mdajwqjn" });
</script>
