---
const navItems = [
  { title: "About", active: true },
  { title: "Resume", active: false },
  { title: "Portfolio", active: false },
  { title: "Contact", active: false },
];
---

<nav class="navbar">
  <ul class="navbar-list">
    {
      navItems.map((item) => (
        <li class="navbar-item">
          <button
            class={`navbar-link ${item.active ? "active" : ""}`}
            aria-current={item.active ? "page" : "false"}
            data-nav-link
            type="button"
          >
            {item.title}
          </button>
        </li>
      ))
    }
  </ul>
</nav>

<script type="module">
  document.addEventListener("DOMContentLoaded", () => {
    const navigationLinks = document.querySelectorAll("[data-nav-link]");
    const pages = document.querySelectorAll("[data-page]");

    if (navigationLinks.length === 0 || pages.length === 0) return;

    navigationLinks.forEach((link) => {
      link.addEventListener("click", function () {
        const current = this.textContent.trim().toLowerCase();

        pages.forEach((page, pageIndex) => {
          const isTarget = current === page.dataset.page;
          page.classList.toggle("active", isTarget);
          navigationLinks[pageIndex].classList.toggle("active", isTarget);
          navigationLinks[pageIndex].setAttribute(
            "aria-current",
            isTarget ? "page" : "false"
          );
        });

        window.scrollTo(0, 0);
      });
    });
  });
</script>
